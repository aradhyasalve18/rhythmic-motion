# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend URLs for CORS
CLIENT_URLS=http://localhost:5173,http://localhost:5174

# ─────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────
# MongoDB connection string (e.g. mongodb+srv://<username>:<password>@cluster.mongodb.net/wedding?retryWrites=true&w=majority)
MONGO_URI=your_mongodb_connection_string_here

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
# Secret key used to sign JSON Web Tokens
JWT_SECRET=your_super_secret_jwt_key_here

# ─────────────────────────────────────────────
# Cloudinary (Image Uploads)
# ─────────────────────────────────────────────
# Get these from your Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
